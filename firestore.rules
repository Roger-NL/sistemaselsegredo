rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "roger@esacademy.com" ||
        request.auth.token.email == "admin@esacademy.com" ||
        request.auth.token.email == "raugerac@gmail.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function ownerWritableUserFields() {
      return [
        "id",
        "name",
        "email",
        "phone",
        "createdAt",
        "currentStreak",
        "lastLoginDate",
        "subscriptionStatus",
        "approvedPillar",
        "chosenSpecialization",
        "specializationStatus",
        "completedSpecializations",
        "completedModules",
        "completedPillarModules",
        "hasSeenMissionComplete"
      ];
    }

    function ownerCanCreateUser(userId) {
      return isOwner(userId) &&
        request.resource.data.id == userId &&
        request.resource.data.subscriptionStatus == "free" &&
        request.resource.data.approvedPillar == 1 &&
        request.resource.data.keys().hasOnly(ownerWritableUserFields());
    }

    function ownerCanUpdateUser() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "name",
        "email",
        "phone",
        "currentStreak",
        "lastLoginDate",
        "chosenSpecialization",
        "specializationStatus",
        "completedSpecializations",
        "completedModules",
        "completedPillarModules",
        "hasSeenMissionComplete"
      ]);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if ownerCanCreateUser(userId) || isAdmin();
      allow update: if (isOwner(userId) && ownerCanUpdateUser()) || isAdmin();
      allow delete: if isAdmin();
    }

    match /pillar_exams/{examId} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == "pending";
      allow read: if (isSignedIn() && request.auth.uid == resource.data.userId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /live_sessions/{sessionId} {
      allow read: if isSignedIn() &&
        (
          request.auth.uid == resource.data.userId ||
          request.auth.uid == resource.data.studentId ||
          isAdmin()
        );
      allow read, write: if isAdmin();
    }

    match /access_requests/{requestId} {
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == "pending" &&
        request.resource.data.currentPillar is int &&
        request.resource.data.requestedPillar is int &&
        request.resource.data.requestedPillar == request.resource.data.currentPillar + 1 &&
        request.resource.data.userName is string &&
        request.resource.data.userEmail is string &&
        request.resource.data.keys().hasOnly([
          "userId",
          "userName",
          "userEmail",
          "currentPillar",
          "requestedPillar",
          "status",
          "createdAt"
        ]);
      allow read: if (isSignedIn() && request.auth.uid == resource.data.userId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /invite_codes/{codeId} {
      allow read, write: if isAdmin();
    }

    match /payment_attempts/{paymentId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /webhook_events/{eventId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
